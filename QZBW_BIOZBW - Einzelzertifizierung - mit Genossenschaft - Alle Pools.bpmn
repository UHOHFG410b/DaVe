      <task completionQuantity="1" id="sid-F617F315-7AB6-4BEA-91BD-B23E0F56D47F" isForCompensation="false" name="Rückstandsuntersuchungen koordinieren" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#FFFF00"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioMetaData metaKey="meta-dctdescription" metaValue="[&quot;Rückstandsuntersuchungen: Lizenznehmer sind verantwortlich für die Organisation und Umsetzung der Rückstandsuntersuchungen auf Pflanzenschutzmittel, Kontaminanten oder Tierarzneimittel. Probenahmen erfolgen in der Regel bei der Erfassung der Agrarerzeugnisse. Die Labore müssen nach DIN EN ISO/IEC 17025 akkreditiert sein, und die Probenahme kann unangemeldet erfolgen.&quot;]"/>
         </extensionElements>
         <incoming>sid-5C87F4B0-F516-41B5-900E-568C10D11228</incoming>
         <outgoing>sid-E86FDA73-6462-4FA2-8243-5C0B1C1CF269</outgoing>
